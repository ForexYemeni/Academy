# SonicAcademy Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الفعلية

# ===== DATABASE =====
# اختر ONE فقط من التالي:

# --- MongoDB Atlas (موصى به للإنتاج) ---
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/sonic_academy?retryWrites=true&w=majority"

# --- PostgreSQL (Neon - للأداء الأعلى) ---
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/sonic_academy?sslmode=require"

# --- MySQL (TiDB Cloud) ---
# DATABASE_URL="mysql://user:pass@gateway01.region.prod.aws.tidbcloud.com:4000/sonic_academy?sslaccept=accept"

# --- SQLite (للتطوير المحلي فقط) ---
# DATABASE_URL="file:./db/custom.db"

# ===== AUTH =====
# مفتاح سري لتوقيع JWT tokens (32+ حرف)
# لتوليد مفتاح: openssl rand -hex 32
JWT_SECRET="change-this-to-a-random-32-char-string"
